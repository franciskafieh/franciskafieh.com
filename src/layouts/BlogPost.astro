---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Nav from "../components/Nav.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"] & { headings?: any[] };

const { title, description, pubDate, updatedDate, heroImage, headings = [] } = Astro.props;

// Filter headings to only show h2 and h3 for the TOC
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<html lang="en">
  <head>
    <BaseHead title={`Francis Kafieh | ${title}`} description={description} />
  </head>

  <body class="min-h-screen relative overflow-x-hidden selection:bg-surface-variant selection:text-on-surface flex flex-col">
    <Nav />

    <main class="w-full px-4 md:px-16 pb-24 flex-1 flex justify-center relative">
      <!-- Left spacer to perfectly center the main article against the right sidebar -->
      <div class="hidden xl:block w-64 shrink-0"></div>

      <div class="w-full max-w-3xl flex flex-col lg:flex-row gap-16 lg:gap-24 items-start mx-auto relative">
        
        <!-- Center Content Area -->
        <article class="w-full max-w-3xl mx-auto p-8 md:p-12 lg:p-16 flex-1">
          
          <div class="mb-12 border-b border-outline-variant/30 pb-12">
            <div class="text-[0.65rem] font-sans font-medium text-outline uppercase tracking-[0.2em] mb-6">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="ml-2 italic">(Updated <FormattedDate date={updatedDate} />)</span>
              )}
            </div>
            <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-normal leading-tight text-on-surface">{title}</h1>
          </div>

          <div class="prose prose-headings:relative group/prose">
            <slot />
          </div>
          
        </article>

      </div>

      <!-- Right Sidebar (TOC) - Absolute positioned to stay out of the centering math -->
      <aside class="hidden xl:flex flex-col w-64 shrink-0 absolute right-16 top-0 sticky-sidebar pt-32 pb-24">
        <div class="text-[0.65rem] font-sans font-medium text-outline uppercase tracking-[0.2em] mb-6">
          Overview
        </div>
        <nav class="flex flex-col gap-3 toc-nav">
          {tocHeadings.length > 0 ? (
            tocHeadings.map((heading) => (
              <a 
                href={`#${heading.slug}`} 
                class={`toc-link text-sm font-sans transition-colors duration-200 ${heading.depth === 2 ? 'text-outline/60' : 'text-outline/40 ml-4'}`}
                data-slug={heading.slug}
              >
                {heading.text}
              </a>
            ))
          ) : (
            <span class="text-sm font-sans text-outline/60 italic">No sections</span>
          )}
        </nav>
        
        <div class="mt-16 text-[0.65rem] font-sans font-medium text-outline uppercase tracking-[0.2em] mb-6">
          Actions
        </div>
        <button id="copy-link-btn" class="text-sm font-sans text-outline hover:text-on-surface transition-colors duration-0 text-left flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-outline rounded-none"></span>
          Copy Page Link
        </button>
        <div id="copy-toast" class="text-xs font-sans text-on-surface mt-2 opacity-0 transition-opacity duration-300">Copied to clipboard!</div>
      </aside>
    </main>

    <style>
      .sticky-sidebar {
        position: sticky;
        top: 0;
      }
      /* Active state for TOC links */
      .toc-link.active {
        color: var(--color-on-surface);
        font-weight: 500;
      }
    </style>

    <script>
      // Make headings clickable to copy their anchor link
      const prose = document.querySelector('.prose');
      if (prose) {
        const headings = prose.querySelectorAll('h2, h3, h4');
        
        // Setup Intersection Observer for TOC highlighting
        const tocLinks = document.querySelectorAll('.toc-link');
        
        const observerOptions = {
          root: null,
          rootMargin: '0px 0px -80% 0px', // Trigger when heading is near the top 20% of viewport
          threshold: 1.0
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Remove active class from all links
              tocLinks.forEach(link => link.classList.remove('active'));
              
              // Add active class to corresponding link
              const id = entry.target.id;
              const activeLink = document.querySelector(`.toc-link[data-slug="${id}"]`);
              if (activeLink) {
                activeLink.classList.add('active');
              }
            }
          });
        }, observerOptions);

        headings.forEach(heading => {
          // Observe heading for TOC
          observer.observe(heading);

          // Copy link functionality
          heading.classList.add('cursor-pointer', 'hover:opacity-70', 'transition-opacity', 'duration-0');
          heading.title = "Click to copy link";
          
          heading.addEventListener('click', () => {
            const id = heading.id;
            if (id) {
              const url = new URL(window.location.href);
              url.hash = id;
              navigator.clipboard.writeText(url.toString());
              
              const originalText = heading.textContent;
              heading.textContent = originalText + " (Copied!)";
              setTimeout(() => {
                heading.textContent = originalText;
              }, 1000);
            }
          });
        });
      }

      // Sidebar copy link button
      const copyBtn = document.getElementById('copy-link-btn');
      const copyToast = document.getElementById('copy-toast');
      
      if (copyBtn && copyToast) {
        copyBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(window.location.href);
          copyToast.classList.remove('opacity-0');
          setTimeout(() => {
            copyToast.classList.add('opacity-0');
          }, 2000);
        });
      }
    </script>
  </body>
</html>
